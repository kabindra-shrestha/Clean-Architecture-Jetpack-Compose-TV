<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.JetpackComposeTVCleanArchitecture" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">#0E061D</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.JetpackComposeTVCleanArchitecture.SplashScreen" parent="Theme.SplashScreen">
